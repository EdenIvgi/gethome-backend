# --- API server ---
PORT=3001
NODE_ENV=development
# Frontend origin for CORS. Use "*" for any (dev only).
CLIENT_URL=http://localhost:5173

# --- Turso (libSQL) ---
# Create at https://turso.tech (no credit card needed).
# Leave blank in dev to fall back to file:./data/gethome.db (local SQLite via libSQL).
TURSO_DATABASE_URL=libsql://gethome-<username>.turso.io
TURSO_AUTH_TOKEN=

# --- JWT ---
# Generate a long random string for production
JWT_SECRET=change-me

# --- Groq LLM (apartment classification) ---
# https://console.groq.com — free tier
GROQ_API_KEY=

# --- Facebook ---
# Dedicated account — do NOT use your personal FB
FB_EMAIL=
FB_PASSWORD=
# Comma-separated group URLs (join manually first)
FB_GROUPS=

# --- Yad2 ---
YAD2_MAX_PAGES=2

# --- Telegram (channel-wide notifications) ---
# Get bot token via @BotFather, chat id via @userinfobot
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
