# Server
PORT=3001
NODE_ENV=development
CLIENT_URL=http://localhost:5173

# Database - SQLite file path
DB_PATH=./data/gethome.db

# JWT secret - change this in production!
JWT_SECRET=gethome-dev-secret-change-in-production

# Scraper toggle - set to true to enable automatic scraping
ENABLE_SCRAPER=false

# Facebook - create a DEDICATED account, don't use personal!
FB_EMAIL=your_fb_email
FB_PASSWORD=your_fb_password
# Comma-separated group URLs (join them manually first!)
FB_GROUPS=https://www.facebook.com/groups/apartments.tlv,https://www.facebook.com/groups/dira.behol.mechiir
# Number of parallel browser tabs for Facebook (default: 4, max recommended: 8)
FB_WORKER_COUNT=4

# Groq API key for LLM classification
GROQ_API_KEY=your_groq_api_key

# Telegram notifications (optional)
# Create a bot via @BotFather, then get your chat ID via @userinfobot
TELEGRAM_BOT_TOKEN=your_bot_token
TELEGRAM_CHAT_ID=your_chat_id

# Yad2
YAD2_MAX_PAGES=3
