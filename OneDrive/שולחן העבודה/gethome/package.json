{
  "name": "gethome",
  "version": "1.0.0",
  "description": "Apartment listing aggregator - Facebook Groups & Yad2",
  "type": "module",
  "main": "backend/index.js",
  "scripts": {
    "start": "node backend/index.js",
    "dev": "node --watch backend/index.js",
    "setup-db": "node backend/db/setup.js",
    "login-fb": "node backend/scraper/facebook/login.js",
    "build": "cd frontend && npm run build",
    "seed": "node backend/db/seed.js",
    "scrape-yad2": "node -e \"import('./backend/scraper/yad2/scraper.js').then(m=>m.scrapeYad2()).then(r=>console.log(r.length+' listings')).catch(console.error)\""
  },
  "keywords": [
    "apartment",
    "aggregator",
    "scraper",
    "yad2",
    "facebook"
  ],
  "license": "MIT",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.78.0",
    "axios": "^1.13.6",
    "better-sqlite3": "^12.8.0",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "groq-sdk": "^1.1.1",
    "node-cron": "^4.2.1",
    "playwright": "^1.58.2",
    "playwright-extra": "^4.3.6",
    "puppeteer-extra-plugin-stealth": "^2.11.2"
  }
}
